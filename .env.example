# Salin file ini menjadi .env (untuk lokal) atau set di dashboard Vercel.

# Koneksi PostgreSQL. Bila DIISI -> aplikasi pakai Postgres.
# Bila DIKOSONGKAN -> aplikasi pakai penyimpanan file JSON (hanya untuk lokal).
#
# Contoh format (ambil dari Vercel Postgres / Neon / Supabase):
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# Port server lokal (opsional, default 3000).
# PORT=3000
